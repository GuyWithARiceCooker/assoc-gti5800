# Másoljad `local.properties` néven a repó gyökerébe. A `local.properties` a .gitignore-ban van — ne add githez.
# Az ASUS-ra való `rsync` scriptek általában *nem* viszik ezt a fájlt: az ASUSon külön add meg ugyanígy, ha ott fut a Gradle.

sdk.dir=/path/to/Android/Sdk

# Felhő (OpenAI) csevegés: kötelező a "Felhő" backendhez. Formátum: sk-... (platformtól függően).
ASSOC_AI_API_KEY=

# Opcionális — helyi Ollama / ASUS: http://LAN-IP:11434
# ASSOC_ASUS_OLLAMA_BASE=http://192.168.0.59:11434
# ASSOC_ASUS_OLLAMA_NATIVE=true
# ASSOC_ASUS_MODEL=deepseek-r1:8b

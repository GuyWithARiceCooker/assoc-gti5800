<?xml version="1.0" encoding="utf-8"?>
<!-- I5800: nincs rádió, nincs ürítés — ne kérjünk ASSOC_AI_API_KEY (felhő), ne legyen túl sok view (inflate / NPE). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="4dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="2dp"
        android:text="@string/ai_title"
        android:textSize="15sp"
        android:textStyle="bold" />

    <ScrollView
        android:id="@+id/ai_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1a1a24"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/ai_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:textColor="#e8e0d0"
            android:textSize="11sp" />
    </ScrollView>

    <EditText
        android:id="@+id/ai_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/ai_input_hint"
        android:inputType="textCapSentences|textMultiLine"
        android:minLines="1" />

    <Button
        android:id="@+id/ai_send"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="40dp"
        android:text="@string/ai_send" />

    <!-- R.id: a ugyanaz a Java mindkét flaforn — az üres/eltűnt id-k nélkül a galaxy3 R nem tudna fordulni. -->
    <Button
        android:id="@+id/ai_clear"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <RadioGroup
        android:id="@+id/ai_backend_group"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone">

        <RadioButton
            android:id="@+id/ai_backend_cloud"
            android:layout_width="0dp"
            android:layout_height="0dp" />
        <RadioButton
            android:id="@+id/ai_backend_asus"
            android:layout_width="0dp"
            android:layout_height="0dp" />
    </RadioGroup>
</LinearLayout>
